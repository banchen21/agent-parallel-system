{
  "toolId": "get_weather",
  "description": "获取指定城市的实时天气与未来预报",
  "parameters": {
    "type": "object",
    "properties": {
      "location": { "type": "string", "description": "城市名称" },
      "days": { "type": "integer", "description": "预报天数 (1-15)" },
      "unit": { "type": "string", "enum": ["celsius", "fahrenheit"] }
    },
    "required": ["location"]
  },
  "options": {
    "timeoutMs": 5000,
    "maxRetries": 2
  }
}