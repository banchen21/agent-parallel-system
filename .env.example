# 应用配置
APP_NAME=Agent Parallel System
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
API_PREFIX=/api/v1

# 服务器配置
HOST=0.0.0.0
PORT=8000
WORKERS=4

# 数据库配置
DATABASE_URL=postgres://postgres:password@localhost:5432/agent_system
DATABASE_POOL_MAX_CONNECTIONS=20
DATABASE_POOL_MIN_CONNECTIONS=5

# Redis配置
REDIS_URL=redis://localhost:6379
REDIS_POOL_SIZE=10

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 安全配置
BCRYPT_COST=12
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=60

# OpenAI配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# 监控配置
OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=info
LOG_FORMAT=json

# 文件存储
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage
STORAGE_MAX_FILE_SIZE=10485760  # 10MB

# 邮件配置（可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@agent-system.com