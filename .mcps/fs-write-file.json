{
  "toolId": "fs_write_file",
  "description": "写入工作空间内文件，支持覆盖或追加",
  "parameters": {
    "type": "object",
    "properties": {
      "workspace_name": { "type": "string", "description": "工作空间名称，例如 banchen_default" },
      "path": { "type": "string", "description": "要写入的相对文件路径" },
      "content": { "type": "string", "description": "写入文本内容" },
      "append": { "type": "boolean", "description": "是否追加写入，默认 false" }
    },
    "required": ["path", "content"]
  },
  "options": {
    "timeoutMs": 8000,
    "maxRetries": 1
  }
}
