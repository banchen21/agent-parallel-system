{
  "toolId": "terminal_run",
  "description": "在工作空间目录下执行 shell 命令并返回 stdout/stderr",
  "parameters": {
    "type": "object",
    "properties": {
      "workspace_name": { "type": "string", "description": "工作空间名称，例如 banchen_default" },
      "cwd": { "type": "string", "description": "相对工作目录，默认 ." },
      "command": { "type": "string", "description": "要执行的 shell 命令" },
      "timeout_ms": { "type": "integer", "description": "超时毫秒，默认 15000" }
    },
    "required": ["command"]
  },
  "options": {
    "timeoutMs": 20000,
    "maxRetries": 0
  }
}
